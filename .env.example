# Backend
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/escrowflow
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_EXPIRES_IN=7d
PORT=3001
FRONTEND_URL=http://localhost:5173

# Nomba API
NOMBA_BASE_URL=https://api.nomba.com/v1
NOMBA_API_KEY=your_nomba_api_key
NOMBA_ACCOUNT_ID=your_nomba_account_id
NOMBA_WEBHOOK_SECRET=your_webhook_signing_secret

# Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@escrowflow.ng

# Frontend
VITE_API_URL=http://localhost:3001

# Cloudinary (evidence upload)
VITE_CLOUDINARY_CLOUD=your_cloud_name
VITE_CLOUDINARY_PRESET=your_upload_preset
