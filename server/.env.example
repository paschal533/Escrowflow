MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/escrowflow
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_EXPIRES_IN=7d
PORT=3001
FRONTEND_URL=http://localhost:5173

# Nomba credentials
# TEST:  NOMBA_BASE_URL=https://sandbox.nomba.com
# LIVE:  NOMBA_BASE_URL=https://api.nomba.com
NOMBA_BASE_URL=https://sandbox.nomba.com
NOMBA_CLIENT_ID=your_client_id
NOMBA_CLIENT_SECRET=your_private_key
NOMBA_PARENT_ACCOUNT_ID=your_parent_account_id
NOMBA_SUB_ACCOUNT_ID=your_sub_account_id
NOMBA_WEBHOOK_SECRET=your_webhook_secret

# Email (SMTP — leave blank to disable)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
